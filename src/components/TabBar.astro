---
const path = Astro.url.pathname;
const tabs = [
  { href: '/', label: 'Hoy', icon: '🗓️' },
  { href: '/entreno', label: 'Entreno', icon: '🏋️' },
  { href: '/dieta', label: 'Dieta', icon: '🍱' },
  { href: '/progreso', label: 'Progreso', icon: '📊' },
];
const activo = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<nav class="tabbar fixed inset-x-0 bottom-0 z-10 border-t border-line bg-surface/95 pb-[env(safe-area-inset-bottom)] backdrop-blur">
  <div class="mx-auto grid max-w-md grid-cols-4">
    {
      tabs.map((t) => {
        const on = activo(t.href);
        return (
          <a
            href={t.href}
            aria-current={on ? 'page' : undefined}
            class={`tab flex flex-col items-center gap-0.5 py-2.5 text-xs font-semibold ${on ? 'tab-on text-vio-hi' : 'text-mut'}`}
          >
            <span class="tab-ico text-2xl leading-none">{t.icon}</span>
            {t.label}
          </a>
        );
      })
    }
  </div>
</nav>
