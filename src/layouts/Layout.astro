---
import { pwaInfo } from 'virtual:pwa-info';
import TabBar from '../components/TabBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Tu "Sistema" de entrenamiento: qué toca hoy, progresión automática de cargas y registro de progreso. PWA local-first: sin backend, sin cuentas.',
} = Astro.props;
const base = Astro.site ?? Astro.url;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        var stored = null;
        try {
          stored = localStorage.getItem('perfilActivo');
        } catch (e) {}
        var p = stored === 'jose' || stored === 'yasmina' ? stored : 'jose';
        document.documentElement.dataset.perfil = p;
        document.documentElement.style.setProperty('color-scheme', 'dark');
        var tc = { jose: '#0a0712', yasmina: '#0a140d' }[p];
        document.addEventListener('DOMContentLoaded', function () {
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', tc);
        });
        var path = location.pathname.replace(/\/+$/, '') || '/';
        if (!stored && path !== '/perfil') location.replace('/perfil');
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0712" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-96x96.png" type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={new URL(Astro.url.pathname, base)} />
    <meta name="apple-mobile-web-app-title" content="GYM" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="System GYM" />
    <meta property="og:title" content={`${title} · System GYM`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/web-app-manifest-512x512.png', base)} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary" />
    <title>{title} · GYM</title>
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script src="../pwa.ts"></script>
  </head>
  <body class="min-h-dvh">
    <header class="sticky top-0 z-10 flex items-center justify-between bg-bg/90 px-5 pt-[calc(env(safe-area-inset-top)+0.75rem)] pb-3 backdrop-blur">
      <h1 class="text-2xl font-extrabold tracking-tight">{title}</h1>
      <a href="/ajustes" class="-m-2 p-2 text-2xl" aria-label="Ajustes">⚙️</a>
    </header>
    <main class="mx-auto max-w-md px-4 pb-28">
      <slot />
    </main>
    <TabBar />
  </body>
</html>
