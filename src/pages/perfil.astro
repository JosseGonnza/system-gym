---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Elige perfil">
  <div class="sel-fondo" aria-hidden="true">
    <div class="sel-arriba"></div>
    <div class="sel-abajo"></div>
  </div>

  <p class="sel-titulo">¿Quién entrena?</p>

  <div class="sel-cards">
    <button id="perfil-jose" class="sel-card sel-jose">
      <span class="sel-emoji">⚔️</span>
      <span>
        <span class="sel-nombre">System Gym</span>
        <span class="sel-sub">Jose · Fuerza + Estética</span>
      </span>
    </button>

    <button id="perfil-yasmina" class="sel-card sel-yasmina">
      <span class="sel-emoji">🍵</span>
      <span>
        <span class="sel-nombre">Matcha Rutine</span>
        <span class="sel-sub">Yasmina · Recomposición</span>
      </span>
    </button>
  </div>
</Layout>

<script>
  import { initDB, setPerfilActivo } from '../lib/db';

  await initDB();

  document.getElementById('perfil-jose')?.addEventListener('click', async () => {
    await setPerfilActivo('jose');
    location.href = '/';
  });
  document.getElementById('perfil-yasmina')?.addEventListener('click', async () => {
    await setPerfilActivo('yasmina');
    location.href = '/';
  });
</script>
