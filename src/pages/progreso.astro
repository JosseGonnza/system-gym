---
import Layout from '../layouts/Layout.astro';
import Ico from '../components/Ico.astro';
---

<Layout title="Progreso">
  <section class="card">
    <div class="flex items-baseline justify-between">
      <h2 class="flex items-center gap-2 text-base font-bold"><Ico id="medidas" emoji="⚖️" /> Peso corporal</h2>
      <p id="peso-actual" class="text-xl font-extrabold text-vio-hi"></p>
    </div>
    <p id="peso-media" class="mt-1 text-xs font-semibold text-mut"></p>
    <div class="mt-3 flex gap-2">
      <input
        id="peso-input"
        type="number"
        step="0.1"
        min="30"
        max="150"
        inputmode="decimal"
        placeholder="kg (en ayunas)"
        class="flex-1 rounded-xl border border-line bg-surface2 px-3 py-2.5 text-base font-bold"
      />
      <button id="peso-add" class="btn w-24 py-2.5">Anotar</button>
    </div>
    <div id="peso-grafico" class="mt-3"></div>
    <ul id="peso-lista" class="mt-3 space-y-1.5 text-sm"></ul>
  </section>

  <section class="card mt-4">
    <div class="flex items-baseline justify-between">
      <h2 class="flex items-center gap-2 text-base font-bold"><Ico id="medidas" emoji="📏" /> Cintura</h2>
      <p id="cintura-actual" class="text-xl font-extrabold text-vio-hi"></p>
    </div>
    <p class="mt-1 text-xs text-mut">Cinta a la altura del ombligo. Si el peso sube y esto no → perfecto.</p>
    <div class="mt-3 flex gap-2">
      <input
        id="cintura-input"
        type="number"
        step="0.5"
        min="50"
        max="150"
        inputmode="decimal"
        placeholder="cm"
        class="flex-1 rounded-xl border border-line bg-surface2 px-3 py-2.5 text-base font-bold"
      />
      <button id="cintura-add" class="btn w-24 py-2.5">Anotar</button>
    </div>
    <div id="cintura-grafico" class="mt-3"></div>
    <ul id="cintura-lista" class="mt-3 space-y-1.5 text-sm"></ul>
  </section>

  <section class="card mt-4">
    <h2 class="flex items-center gap-2 text-base font-bold"><Ico id="record" emoji="🏆" /> Marcas por ejercicio</h2>
    <select
      id="marca-select"
      class="mt-3 w-full rounded-xl border border-line bg-surface2 px-3 py-2.5 text-sm font-bold"
    ></select>
    <p id="marca-mejor" class="mt-2 text-sm font-bold text-vio-hi"></p>
    <div id="marca-grafico" class="mt-3"></div>
    <ul id="marca-lista" class="mt-3 space-y-1.5 text-sm text-mut"></ul>
  </section>
</Layout>

<script>
  import {
    initDB,
    getConfig,
    getRutinas,
    getSesiones,
    getMediciones,
    setMediciones,
    hoyISO,
  } from '../lib/db';
  import { historialDeRanura, type PuntoHistorial } from '../lib/motor';
  import { cerrarBorradoresCaducados } from '../lib/sesion';
  import type { EjercicioDef, SerieReg } from '../lib/types';

  const $ = (id: string) => document.getElementById(id)!;
  const fmtFecha = (iso: string) =>
    new Date(`${iso}T12:00:00`).toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  const fmtNum = (n: number) => n.toLocaleString('es-ES', { maximumFractionDigits: 2 });

  await initDB();
  await cerrarBorradoresCaducados();
  const config = await getConfig();
  const rutinas = await getRutinas();
  const rutina = rutinas.find((r) => r.id === config.rutinaActivaId) ?? rutinas[0];
  const sesiones = await getSesiones();
  const mediciones = await getMediciones();

  function grafico(valores: { fecha: string; v: number }[], unidad: string): HTMLElement {
    const wrap = document.createElement('div');
    if (valores.length < 2) {
      wrap.className = 'rounded-xl bg-surface2 px-3 py-4 text-center text-xs text-mut';
      wrap.textContent =
        valores.length === 1
          ? `Primer dato: ${fmtNum(valores[0].v)} ${unidad}. Con el segundo ya hay línea.`
          : 'Sin datos todavía.';
      return wrap;
    }
    const W = 320;
    const H = 90;
    const P = 8;
    const vs = valores.map((d) => d.v);
    const min = Math.min(...vs);
    const max = Math.max(...vs);
    const span = max - min || 1;
    const x = (i: number) => P + (i * (W - 2 * P)) / (valores.length - 1);
    const y = (v: number) => H - P - ((v - min) * (H - 2 * P)) / span;
    const pts = valores.map((d, i) => `${x(i)},${y(d.v)}`).join(' ');
    const fin = valores[valores.length - 1];
    wrap.innerHTML = `
      <svg viewBox="0 0 ${W} ${H}" class="w-full text-vio-hi">
        <polyline points="${pts}" fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linejoin="round" stroke-linecap="round"
          style="filter: drop-shadow(0 0 6px color-mix(in srgb, currentColor 55%, transparent))"/>
        <circle cx="${x(valores.length - 1)}" cy="${y(fin.v)}" r="4" fill="currentColor"/>
      </svg>
      <div class="num flex justify-between text-[10px] text-mut">
        <span>${fmtFecha(valores[0].fecha)}</span>
        <span>mín ${fmtNum(min)} · máx ${fmtNum(max)} ${unidad}</span>
        <span>${fmtFecha(fin.fecha)}</span>
      </div>`;
    return wrap;
  }

  // ---------- Peso y cintura ----------
  function mediaSemana(entradas: { fecha: string; kg: number }[], offsetSemanas: number): number | null {
    const hoy = new Date();
    const lunes = new Date(hoy);
    lunes.setDate(hoy.getDate() - ((hoy.getDay() + 6) % 7) - offsetSemanas * 7);
    const ini = hoyISO(lunes);
    const fin = hoyISO(new Date(lunes.getTime() + 6 * 86_400_000));
    const xs = entradas.filter((e) => e.fecha >= ini && e.fecha <= fin).map((e) => e.kg);
    return xs.length ? xs.reduce((a, b) => a + b, 0) / xs.length : null;
  }

  function listaMediciones(
    ul: HTMLElement,
    entradas: { fecha: string; [k: string]: string | number }[],
    campo: 'kg' | 'cm',
    unidad: string,
    onBorrar: (fecha: string) => void,
  ) {
    ul.replaceChildren(
      ...entradas
        .slice(-5)
        .reverse()
        .map((e) => {
          const li = document.createElement('li');
          li.className = 'flex items-center justify-between text-mut';
          const txt = document.createElement('span');
          txt.textContent = `${fmtFecha(e.fecha)} — ${fmtNum(e[campo] as number)} ${unidad}`;
          const del = document.createElement('button');
          del.className = 'px-2 text-xs';
          del.textContent = '🗑';
          del.addEventListener('click', () => {
            if (confirm(`¿Borrar la medición del ${fmtFecha(e.fecha)}?`)) onBorrar(e.fecha);
          });
          li.append(txt, del);
          return li;
        }),
    );
  }

  function renderPeso() {
    const entradas = [...mediciones.peso].sort((a, b) => a.fecha.localeCompare(b.fecha));
    const ultima = entradas[entradas.length - 1];
    $('peso-actual').textContent = ultima ? `${fmtNum(ultima.kg)} kg` : '—';
    const ahora = mediaSemana(entradas, 0);
    const previa = mediaSemana(entradas, 1);
    if (ahora != null && previa != null) {
      const delta = ahora - previa;
      const signo = delta >= 0 ? '+' : '';
      const enRango = delta >= 0.15 && delta <= 0.35;
      $('peso-media').textContent = `Media semanal: ${fmtNum(ahora)} kg (${signo}${fmtNum(delta)} vs anterior · objetivo +0,2-0,3)`;
      $('peso-media').className = `mt-1 text-xs font-semibold ${enRango ? 'text-ok' : 'text-warn'}`;
    } else if (ahora != null) {
      $('peso-media').textContent = `Media de esta semana: ${fmtNum(ahora)} kg`;
    } else {
      $('peso-media').textContent = 'Pésate en ayunas 2-3 veces por semana y mira la media, no el día suelto.';
    }
    $('peso-grafico').replaceChildren(grafico(entradas.slice(-60).map((e) => ({ fecha: e.fecha, v: e.kg })), 'kg'));
    listaMediciones($('peso-lista'), entradas, 'kg', 'kg', async (fecha) => {
      mediciones.peso = mediciones.peso.filter((e) => e.fecha !== fecha);
      await setMediciones(mediciones);
      renderPeso();
    });
  }

  function renderCintura() {
    const entradas = [...mediciones.cintura].sort((a, b) => a.fecha.localeCompare(b.fecha));
    const ultima = entradas[entradas.length - 1];
    $('cintura-actual').textContent = ultima ? `${fmtNum(ultima.cm)} cm` : '—';
    $('cintura-grafico').replaceChildren(grafico(entradas.slice(-60).map((e) => ({ fecha: e.fecha, v: e.cm })), 'cm'));
    listaMediciones($('cintura-lista'), entradas, 'cm', 'cm', async (fecha) => {
      mediciones.cintura = mediciones.cintura.filter((e) => e.fecha !== fecha);
      await setMediciones(mediciones);
      renderCintura();
    });
  }

  $('peso-add').addEventListener('click', async () => {
    const input = $('peso-input') as HTMLInputElement;
    const kg = Number(input.value);
    if (!Number.isFinite(kg) || kg <= 0) return;
    mediciones.peso = mediciones.peso.filter((e) => e.fecha !== hoyISO());
    mediciones.peso.push({ fecha: hoyISO(), kg });
    await setMediciones(mediciones);
    input.value = '';
    renderPeso();
  });

  $('cintura-add').addEventListener('click', async () => {
    const input = $('cintura-input') as HTMLInputElement;
    const cm = Number(input.value);
    if (!Number.isFinite(cm) || cm <= 0) return;
    mediciones.cintura = mediciones.cintura.filter((e) => e.fecha !== hoyISO());
    mediciones.cintura.push({ fecha: hoyISO(), cm });
    await setMediciones(mediciones);
    input.value = '';
    renderCintura();
  });

  // ---------- Marcas por ejercicio ----------
  const ejercicios: { def: EjercicioDef; dia: string }[] = rutina.dias.flatMap((d) =>
    d.ejercicios.map((e) => ({ def: e, dia: `D${rutina.dias.indexOf(d) + 1}` })),
  );

  function valorSesion(def: EjercicioDef, p: PuntoHistorial, usarLastre: boolean): number | null {
    const hechas = p.series.filter((s: SerieReg) => s.estado === 'completada');
    const usar = hechas.length ? hechas : p.series.filter((s: SerieReg) => s.estado !== 'pendiente');
    if (!usar.length) return null;
    if (def.tipoProgresion === 'tiempo') return Math.max(...usar.map((s) => s.segundos ?? 0)) || null;
    if (def.tipoProgresion === 'pesoCorporal') {
      if (usarLastre) return Math.max(...usar.map((s) => s.lastreKg ?? 0));
      return Math.max(...usar.map((s) => s.reps ?? 0)) || null;
    }
    if (def.tipoProgresion === 'libre') return Math.max(...usar.map((s) => s.reps ?? 0)) || null;
    return Math.max(...usar.map((s) => s.peso ?? 0)) || null;
  }

  function renderMarca() {
    const ranuraId = ($('marca-select') as HTMLSelectElement).value;
    const item = ejercicios.find((x) => x.def.ranuraId === ranuraId)!;
    const historial = historialDeRanura(sesiones, ranuraId).slice().reverse();
    const usarLastre =
      item.def.tipoProgresion === 'pesoCorporal' &&
      historial.some((p) => p.series.some((s) => (s.lastreKg ?? 0) > 0));
    const unidad =
      item.def.tipoProgresion === 'tiempo'
        ? 's'
        : item.def.tipoProgresion === 'pesoCorporal'
          ? usarLastre
            ? 'kg lastre'
            : 'reps'
          : item.def.tipoProgresion === 'libre'
            ? 'reps'
            : 'kg';
    const puntos = historial
      .map((p) => ({ fecha: p.fecha, v: valorSesion(item.def, p, usarLastre) }))
      .filter((x): x is { fecha: string; v: number } => x.v != null && (!usarLastre || x.v > 0));

    const mejor = puntos.reduce<{ fecha: string; v: number } | null>(
      (m, p) => (m == null || p.v > m.v ? p : m),
      null,
    );
    $('marca-mejor').textContent = mejor
      ? `Mejor: ${fmtNum(mejor.v)} ${unidad} (${fmtFecha(mejor.fecha)}) · ${puntos.length} sesiones`
      : 'Sin sesiones finalizadas con este ejercicio todavía.';
    $('marca-grafico').replaceChildren(grafico(puntos.slice(-30), unidad));
    $('marca-lista').replaceChildren(
      ...puntos
        .slice(-5)
        .reverse()
        .map((p) => {
          const li = document.createElement('li');
          li.textContent = `${fmtFecha(p.fecha)} — ${fmtNum(p.v)} ${unidad}`;
          return li;
        }),
    );
  }

  const select = $('marca-select') as HTMLSelectElement;
  select.replaceChildren(
    ...ejercicios.map(({ def, dia }) => {
      const o = document.createElement('option');
      o.value = def.ranuraId;
      o.textContent = `${dia} · ${def.nombre}`;
      return o;
    }),
  );
  const primeraConDatos = ejercicios.find((x) => historialDeRanura(sesiones, x.def.ranuraId).length > 0);
  if (primeraConDatos) select.value = primeraConDatos.def.ranuraId;
  select.addEventListener('change', renderMarca);

  renderPeso();
  renderCintura();
  renderMarca();
</script>
