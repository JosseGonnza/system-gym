---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dieta">
  <section id="macros" class="grid grid-cols-4 gap-2"></section>
  <div id="platos" class="mt-4 space-y-3"></div>
  <p id="resumen" class="mt-4 px-1 text-xs text-mut"></p>
</Layout>

<script>
  import { initDB, getPerfilActivo } from '../lib/db';
  import { dietaDe } from '../lib/dietas';

  const $ = (id: string) => document.getElementById(id)!;

  await initDB();
  const dieta = dietaDe(getPerfilActivo());

  $('macros').replaceChildren(
    ...dieta.macros.map((m) => {
      const div = document.createElement('div');
      div.className = 'card px-1 py-3 text-center';
      const v = document.createElement('p');
      v.className = `text-base font-extrabold ${m.color}`;
      v.textContent = m.valor;
      const u = document.createElement('p');
      u.className = 'mt-0.5 text-[10px] uppercase tracking-wide text-mut';
      u.textContent = m.unidad;
      div.append(v, u);
      return div;
    }),
  );

  $('platos').replaceChildren(
    ...dieta.platos.map((p) => {
      const sec = document.createElement('section');
      sec.className = 'card';
      const h = document.createElement('h2');
      h.className = 'text-base font-bold';
      h.textContent = `${p.emoji} ${p.nombre}`;
      sec.append(h);
      if (p.kcal) {
        const k = document.createElement('p');
        k.className = 'mt-0.5 text-xs font-semibold text-vio-hi';
        k.textContent = p.kcal;
        sec.append(k);
      }
      const f = document.createElement('p');
      f.className = 'mt-2 text-sm font-medium text-vio-soft';
      f.textContent = p.formula;
      sec.append(f);
      const ul = document.createElement('ul');
      ul.className = 'mt-1.5 space-y-1 text-sm text-mut';
      for (const d of p.detalle) {
        const li = document.createElement('li');
        li.textContent = d;
        ul.append(li);
      }
      sec.append(ul);
      return sec;
    }),
  );

  $('resumen').textContent = dieta.resumen;
</script>
