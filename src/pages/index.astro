---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hoy">
  <p id="fecha" class="-mt-1 mb-4 text-sm font-medium capitalize text-mut"></p>

  <section>
    <div id="sel-jornada" class="grid grid-cols-3 gap-2"></div>
    <ul id="pauta" class="card mt-3 hidden space-y-2 text-sm"></ul>
  </section>

  <section id="card-entreno" class="card glow mt-4 border-vio/40">
    <div class="flex items-center justify-between">
      <p class="text-xs font-bold uppercase tracking-widest text-vio-hi">Entreno de hoy</p>
      <p id="chip-descansos" class="text-xs font-semibold text-mut"></p>
    </div>
    <h2 id="dia-nombre" class="mt-1 text-xl font-extrabold">Cargando…</h2>
    <ul id="dia-ejercicios" class="mt-3 space-y-1.5 text-sm text-mut"></ul>
    <div class="mt-4 grid grid-cols-2 gap-2">
      <button id="btn-cambiar" class="btn-2 py-2.5 text-sm">🔁 Cambiar día</button>
      <button id="btn-descanso" class="btn-2 py-2.5 text-sm">😴 Descanso hoy</button>
    </div>
  </section>

  <section id="card-manana" class="card mt-4">
    <button id="manana-toggle" class="flex w-full items-center justify-between text-left">
      <h2 class="text-base font-bold">🌙 Mañana</h2>
      <span id="manana-flecha" class="text-mut transition-transform">▾</span>
    </button>
    <div id="manana-cuerpo" class="hidden">
      <p id="manana-fecha" class="mt-1 text-xs capitalize text-mut"></p>
      <div id="sel-jornada-manana" class="mt-3 grid grid-cols-3 gap-2"></div>
      <div class="mt-3 rounded-xl bg-surface2 p-3">
        <p id="manana-entreno" class="text-sm font-semibold"></p>
        <p id="manana-horario" class="mt-1 text-xs text-mut"></p>
        <p id="manana-alarma" class="mt-2 text-sm font-bold text-vio-hi"></p>
      </div>
    </div>
  </section>

  <a
    id="aviso-backup"
    href="/ajustes"
    class="card mt-4 hidden border-warn/40 text-sm font-semibold text-warn"
  ></a>

  <dialog id="dlg-descanso" class="m-auto w-[88%] max-w-sm rounded-2xl border border-warn/40 bg-surface p-5 text-ink backdrop:bg-black/70">
    <p class="text-3xl">⚠️</p>
    <h3 class="mt-2 text-lg font-extrabold">Ya llevas 2 descansos esta semana</h3>
    <p class="mt-2 text-sm text-mut">El plan son 5 entrenos por semana. Un tercer descanso lo deja en 4. Tú decides — pero que sea decisión, no pereza.</p>
    <div class="mt-4 grid gap-2">
      <button id="dlg-descanso-entrenar" class="btn">💪 Voy a entrenar</button>
      <button id="dlg-descanso-confirmar" class="btn-2 text-warn">Descansar igual</button>
    </div>
  </dialog>

  <dialog id="dlg-cambiar" class="m-auto w-[88%] max-w-sm rounded-2xl border border-line bg-surface p-5 text-ink backdrop:bg-black/70">
    <h3 class="text-lg font-extrabold">¿Qué día haces hoy?</h3>
    <p class="mt-1 text-xs text-mut">Cero deuda: el puntero salta al día que hagas.</p>
    <div id="dlg-cambiar-lista" class="mt-3 grid gap-2"></div>
    <button id="dlg-cambiar-cerrar" class="btn-2 mt-3 py-2.5 text-sm">Cancelar</button>
  </dialog>
</Layout>

<script>
  import {
    initDB,
    getConfig,
    getRutinas,
    getSesiones,
    getDiario,
    patchDia,
    hoyISO,
    diaSugerido,
    siguienteDia,
    formatObjetivo,
    contarDescansos,
    getPerfilActivo,
  } from '../lib/db';
  import { horarioDe } from '../lib/horarios';
  import { cerrarBorradoresCaducados } from '../lib/sesion';
  import type { DiaDef } from '../lib/types';

  const $ = (id: string) => document.getElementById(id)!;

  await initDB();
  const { jornadas: JORNADAS, pautas: PAUTAS, alarmas: ALARMAS } = horarioDe(getPerfilActivo());
  await cerrarBorradoresCaducados();
  const config = await getConfig();
  const rutinas = await getRutinas();
  const sesiones = await getSesiones();
  const rutina = rutinas.find((r) => r.id === config.rutinaActivaId) ?? rutinas[0];
  let diario = await getDiario();

  const hoy = hoyISO();
  const mananaDate = new Date();
  mananaDate.setDate(mananaDate.getDate() + 1);
  const manana = hoyISO(mananaDate);
  const entrenadoHoy = sesiones.some((s) => s.fecha === hoy && s.estado === 'finalizada');

  $('fecha').textContent = new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
  $('manana-fecha').textContent = mananaDate.toLocaleDateString('es-ES', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
  });

  const finalizadasTotal = sesiones.filter((s) => s.estado === 'finalizada').length;
  const diasSinExport = config.ultimoExportISO
    ? Math.floor((Date.now() - Date.parse(config.ultimoExportISO)) / 86_400_000)
    : null;
  if (finalizadasTotal > 0 && (diasSinExport === null || diasSinExport >= 7)) {
    const aviso = $('aviso-backup');
    aviso.textContent =
      diasSinExport === null
        ? '💾 Aún no has exportado ningún backup. Toca aquí y guárdalo en Drive o en el PC.'
        : `💾 Hace ${diasSinExport} días que no exportas backup. Toca aquí — son 10 segundos.`;
    aviso.classList.remove('hidden');
    aviso.classList.add('block');
  }

  const numeroDe = (dia: DiaDef) => rutina.dias.findIndex((d) => d.id === dia.id) + 1;
  const tituloDe = (dia: DiaDef) => `${dia.emoji} Día ${numeroDe(dia)} — ${dia.nombre}`;

  function diaEfectivoHoy(): DiaDef {
    const elegido = diario[hoy]?.diaElegidoId;
    return rutina.dias.find((d) => d.id === elegido) ?? diaSugerido(config, rutina);
  }

  function pintarSelector(contenedor: HTMLElement, fecha: string) {
    contenedor.replaceChildren(
      ...JORNADAS.map((j) => {
        const activo = diario[fecha]?.jornada === j.id;
        const b = document.createElement('button');
        b.className = `rounded-xl border py-2.5 text-sm font-bold transition active:scale-[.97] ${
          activo ? 'border-vio bg-vio/20 text-vio-hi glow' : 'border-line bg-surface text-mut'
        }`;
        b.textContent = `${j.emoji} ${j.label}`;
        b.addEventListener('click', async () => {
          diario = await patchDia(fecha, { jornada: j.id });
          render();
        });
        return b;
      }),
    );
  }

  function pintarPauta() {
    const ul = $('pauta');
    const jornada = diario[hoy]?.jornada;
    const filas = jornada ? PAUTAS[jornada] : undefined;
    if (!filas) {
      ul.classList.add('hidden');
      return;
    }
    ul.classList.remove('hidden');
    ul.replaceChildren(
      ...filas.map((fila) => {
        const li = document.createElement('li');
        li.className = `flex gap-3 ${fila.destacado ? 'font-bold text-vio-soft' : 'text-mut'}`;
        const hora = document.createElement('span');
        hora.className = 'w-14 shrink-0 text-right font-semibold tabular-nums';
        hora.textContent = fila.hora;
        const texto = document.createElement('span');
        texto.textContent = fila.texto;
        li.append(hora, texto);
        return li;
      }),
    );
  }

  function pintarEntreno() {
    const descanso = diario[hoy]?.descanso;
    const ul = $('dia-ejercicios');
    const btnDescanso = $('btn-descanso');
    if (descanso) {
      $('dia-nombre').textContent = '😴 Hoy descansas';
      ul.replaceChildren();
      const li = document.createElement('li');
      li.textContent = 'Recuperar también es entrenar. Come bien y duerme.';
      ul.append(li);
      btnDescanso.textContent = '↩️ He cambiado de idea';
      $('btn-cambiar').classList.add('hidden');
      return;
    }
    $('btn-cambiar').classList.remove('hidden');
    btnDescanso.textContent = '😴 Descanso hoy';
    const dia = diaEfectivoHoy();
    $('dia-nombre').textContent = entrenadoHoy ? `✅ Hecho — ${tituloDe(dia)}` : tituloDe(dia);
    ul.replaceChildren(
      ...dia.ejercicios.map((e) => {
        const li = document.createElement('li');
        li.className = 'flex justify-between gap-3';
        const nombre = document.createElement('span');
        nombre.textContent = e.nombre;
        const objetivo = document.createElement('span');
        objetivo.className = 'shrink-0 font-semibold text-vio-soft';
        objetivo.textContent = formatObjetivo(e);
        li.append(nombre, objetivo);
        return li;
      }),
    );
  }

  function pintarDescansos() {
    const n = contarDescansos(sesiones, diario, config.fechaInicioPlan);
    const chip = $('chip-descansos');
    chip.textContent = `Descansos: ${n} / 2`;
    chip.className = `text-xs font-semibold ${n > 2 ? 'text-warn' : 'text-mut'}`;
  }

  function pintarManana() {
    const jornadaM = diario[manana]?.jornada;
    const previsto = entrenadoHoy
      ? diaSugerido(config, rutina)
      : diario[hoy]?.descanso
        ? diaEfectivoHoy()
        : siguienteDia(rutina, diaEfectivoHoy().id);
    const coletilla = !entrenadoHoy && !diario[hoy]?.descanso ? ' (si hoy completas el de hoy)' : '';
    $('manana-entreno').textContent = `Entreno previsto: ${tituloDe(previsto)}${coletilla}`;
    const pauta = jornadaM ? PAUTAS[jornadaM] : undefined;
    if (jornadaM && pauta) {
      const entrenoFila = pauta.find((f) => f.texto.includes('ENTRENO'));
      const label = JORNADAS.find((j) => j.id === jornadaM)?.label.toLowerCase() ?? '';
      $('manana-horario').textContent = `Jornada de ${label} · entreno a las ${entrenoFila?.hora ?? '—'}`;
      $('manana-alarma').textContent = `⏰ Pon la alarma a las ${ALARMAS[jornadaM] ?? 'según turno'}`;
    } else {
      $('manana-horario').textContent = 'Elige jornada para ver horario y alarma.';
      $('manana-alarma').textContent = '';
    }
  }

  function render() {
    pintarSelector($('sel-jornada'), hoy);
    pintarSelector($('sel-jornada-manana'), manana);
    pintarPauta();
    pintarEntreno();
    pintarDescansos();
    pintarManana();
  }

  render();

  const cuerpoManana = $('manana-cuerpo');
  const abrirManana = (abrir: boolean) => {
    cuerpoManana.classList.toggle('hidden', !abrir);
    $('manana-flecha').classList.toggle('rotate-180', abrir);
  };
  $('manana-toggle').addEventListener('click', () => abrirManana(cuerpoManana.classList.contains('hidden')));

  if (new Date().getHours() >= 20 && (entrenadoHoy || diario[hoy]?.descanso)) {
    abrirManana(true);
    $('card-manana').classList.add('glow', 'border-vio/40');
  }

  const dlgDescanso = $('dlg-descanso') as HTMLDialogElement;
  $('btn-descanso').addEventListener('click', async () => {
    if (diario[hoy]?.descanso) {
      diario = await patchDia(hoy, { descanso: false });
      render();
      return;
    }
    if (contarDescansos(sesiones, diario, config.fechaInicioPlan) >= 2) {
      dlgDescanso.showModal();
      return;
    }
    diario = await patchDia(hoy, { descanso: true });
    render();
  });
  $('dlg-descanso-entrenar').addEventListener('click', () => dlgDescanso.close());
  $('dlg-descanso-confirmar').addEventListener('click', async () => {
    dlgDescanso.close();
    diario = await patchDia(hoy, { descanso: true });
    render();
  });

  const dlgCambiar = $('dlg-cambiar') as HTMLDialogElement;
  $('btn-cambiar').addEventListener('click', () => {
    $('dlg-cambiar-lista').replaceChildren(
      ...rutina.dias.map((d) => {
        const b = document.createElement('button');
        const actual = diaEfectivoHoy().id === d.id;
        b.className = `rounded-xl border py-3 text-sm font-bold transition active:scale-[.97] ${
          actual ? 'border-vio bg-vio/20 text-vio-hi' : 'border-line bg-surface2'
        }`;
        b.textContent = tituloDe(d);
        b.addEventListener('click', async () => {
          diario = await patchDia(hoy, { diaElegidoId: d.id });
          dlgCambiar.close();
          render();
        });
        return b;
      }),
    );
    dlgCambiar.showModal();
  });
  $('dlg-cambiar-cerrar').addEventListener('click', () => dlgCambiar.close());
</script>
